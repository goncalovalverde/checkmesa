generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  /// ADMIN | STAFF
  role      String   @default("STAFF")
  password  String
  createdAt DateTime @default(now())

  sessions TableSession[]
}

model Table {
  id       String @id @default(cuid())
  name     String @unique
  capacity Int    @default(4)
  /// FREE | OCCUPIED
  status   String @default("FREE")

  sessions TableSession[]
}

model Product {
  id         String   @id @default(cuid())
  name       String
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  finalPrice Float
  basePrice  Float
  vatAmount  Float
  vatRate    Float
  active     Boolean  @default(true)

  orderItems OrderItem[]
}

model TableSession {
  id        String    @id @default(cuid())
  tableId   String
  openedBy  String
  consumers Int
  /// OPEN | CLOSED
  status    String    @default("OPEN")
  openedAt  DateTime  @default(now())
  closedAt  DateTime?

  table      Table       @relation(fields: [tableId], references: [id])
  user       User        @relation(fields: [openedBy], references: [id])
  orderItems OrderItem[]
}

model Category {
  id         String    @id @default(cuid())
  name       String    @unique
  vatRateId  String
  vatRate    VatRate   @relation(fields: [vatRateId], references: [id])
  products   Product[]
}

model VatRate {
  id         String     @id @default(cuid())
  label      String     @unique
  rate       Float
  categories Category[]
}

model OrderItem {
  id        String   @id @default(cuid())
  sessionId String
  productId String
  quantity  Int      @default(1)
  unitPrice Float
  addedAt   DateTime @default(now())

  session TableSession @relation(fields: [sessionId], references: [id])
  product Product      @relation(fields: [productId], references: [id])
}
